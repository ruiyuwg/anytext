{
  "name": "anytext-cli",
  "version": "0.1.0",
  "description": "Instant, clean documentation for coding agents",
  "type": "module",
  "bin": {
    "anytext": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ruiyuwg/anytext.git"
  },
  "homepage": "https://github.com/ruiyuwg/anytext",
  "keywords": [
    "documentation",
    "cli",
    "llm",
    "coding-agents",
    "markdown",
    "ai",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
